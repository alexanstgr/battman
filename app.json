{
  "expo": {
    "name": "Battman",
    "slug": "battman",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "battman",
    "updates": {
      "enabled": false
    },
    "android": {
      "package": "com.battman.alexanstgr",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-font",
      "@react-native-vector-icons/ionicons",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/logo.png",
          "imageWidth": 406
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "01f17b9e-c863-4021-be3a-e7b9f0ad1866"
      }
    }
  }
}
